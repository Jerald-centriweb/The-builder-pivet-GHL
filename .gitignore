# Output files — audit/audit_data.json kept in repo for Claude; timestamped backups ignored
audit/audit_data_*.json
audit_data.json
!audit/audit_data.json

# Environment and secrets — NEVER commit these
.env
.env.local
.env.production
*.env
mcp/.env
secrets.json
credentials.json

# Node / MCP server build artifacts (installed locally, not committed)
node_modules/
dist/
build/
*.js.map

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/settings.json
*.swp
*.swo

# Logs
*.log
npm-debug.log*

# Python cache
__pycache__/
*.pyc
*.pyo
